# ============================================================
# LLM Configuration
# ============================================================
# Pilih salah satu provider di bawah ini

# ---- OPSI A: Google Gemini (GRATIS) ⭐ RECOMMENDED ----
# Dapatkan API Key: https://aistudio.google.com/apikey
LLM_API_KEY=AIzaSy-your-gemini-api-key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.0-flash

# ---- OPSI B: Groq (GRATIS) ⭐ CEPAT ----
# Dapatkan API Key: https://console.groq.com/
# LLM_API_KEY=gsk-your-groq-api-key
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# ---- OPSI C: OpenRouter (Model Gratis Tersedia) ----
# Dapatkan API Key: https://openrouter.ai/
# Model gratis: meta-llama/llama-3.3-70b-instruct:free
# LLM_API_KEY=sk-or-your-openrouter-key
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ---- OPSI D: OpenAI (Berbayar) ----
# Dapatkan API Key: https://platform.openai.com/
# LLM_API_KEY=sk-proj-your-openai-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ---- OPSI E: Ollama (Lokal - GRATIS) ----
# Install dari https://ollama.ai/, lalu jalankan: ollama run llama3.2
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# ============================================================
# Google Sheets Configuration
# ============================================================
# Path ke file credentials.json (untuk lokal)
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# ATAU gunakan base64 (untuk cloud deployment)
# GOOGLE_CREDENTIALS_BASE64=<base64-encoded-credentials-json>

# ID Google Spreadsheet Anda
SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here

# ============================================================
# WhatsApp Configuration
# ============================================================
# Path untuk menyimpan session WhatsApp
WHATSAPP_SESSION_DB_PATH=./session.db

# Nomor WhatsApp owner (tanpa +, dengan kode negara)
# Ini adalah nomor yang BOLEH mengirim perintah ke bot
OWNER_PHONE_NUMBER=6281234567890

# Metode login WhatsApp: "qr" atau "pairing_code"
# - qr: Scan QR code (default, lebih mudah)
# - pairing_code: Masukkan 8 digit kode (lebih aman, anti-ban)
WHATSAPP_LOGIN_METHOD=qr

# Nomor WhatsApp untuk pairing code (jika metode = pairing_code)
# Ini adalah nomor yang akan digunakan oleh BOT
# Format: kode negara + nomor (tanpa +)
# WHATSAPP_BOT_NUMBER=6281234567890

# ============================================================
# Sales/Business Configuration
# ============================================================
# Nama supplier utama
SUPPLIER_NAME=Toko Supplier

# Tanggal pembayaran supplier setiap bulan (1-31)
SUPPLIER_PAY_DAY=25

# Waktu reminder otomatis (format HH:MM, default 08:00)
REMINDER_TIME=08:00

# Kirim reminder ke customer via WhatsApp (true/false)
WA_REMINDER_TO_CUSTOMER=false
