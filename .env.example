# ============================================================
# LLM Configuration
# ============================================================
# Pilih provider: openai, openrouter, atau ollama
LLM_PROVIDER=openai

# OpenAI Configuration
LLM_API_KEY=your-openai-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# OpenRouter Configuration (alternatif OpenAI)
# LLM_PROVIDER=openrouter
# LLM_API_KEY=your-openrouter-api-key-here
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini

# Ollama Configuration (LLM lokal - gratis)
# LLM_PROVIDER=ollama
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# ============================================================
# Google Sheets Configuration
# ============================================================
# Path ke file credentials.json (untuk lokal)
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# ATAU gunakan base64 (untuk cloud deployment)
# GOOGLE_CREDENTIALS_BASE64=<base64-encoded-credentials-json>

# ID Google Spreadsheet Anda
SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here

# ============================================================
# WhatsApp Configuration
# ============================================================
# Path untuk menyimpan session WhatsApp
WHATSAPP_SESSION_DB_PATH=./session.db

# Nomor WhatsApp owner (tanpa +, dengan kode negara)
OWNER_PHONE_NUMBER=6281234567890

# ============================================================
# Sales/Business Configuration
# ============================================================
# Nama supplier utama
SUPPLIER_NAME=Toko Supplier

# Tanggal pembayaran supplier setiap bulan (1-31)
SUPPLIER_PAY_DAY=25

# Waktu reminder otomatis (format HH:MM, default 08:00)
REMINDER_TIME=08:00

# Kirim reminder ke customer via WhatsApp (true/false)
WA_REMINDER_TO_CUSTOMER=false
